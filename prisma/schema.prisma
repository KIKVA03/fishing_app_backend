// Prisma schema for the FishMap Georgia backend.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Supabase: pooled connection (PgBouncer, port 6543) for the running app.
  url       = env("DATABASE_URL")
  // Supabase: direct connection (port 5432) used by `prisma migrate`.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  password     String // bcrypt hash — never returned to clients
  avatar       String   @default("🎣") // emoji string, e.g. "🎣"
  isAdmin      Boolean  @default(false) @map("is_admin") // grants access to /admin panel
  totalCatches Int      @default(0) @map("total_catches")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  catches  Catch[]
  comments Comment[]

  @@map("users")
}

// Holds a pending registration until the user proves they own the email by
// entering the code we mailed them. No real User row exists until then, so fake
// emails never become accounts. One row per email (re-requesting overwrites it).
model EmailVerification {
  email        String   @id
  username     String
  passwordHash String   @map("password_hash") // bcrypt hash of the chosen password
  avatar       String // pre-picked avatar so the created user matches what we showed
  codeHash     String   @map("code_hash") // bcrypt hash of the 6-digit code
  attempts     Int      @default(0) // wrong-code tries (locks after a few)
  expiresAt    DateTime @map("expires_at")
  lastSentAt   DateTime @default(now()) @map("last_sent_at") // for resend cooldown
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("email_verifications")
}

// Per-species bait knowledge shown in the app's fish-info modal. One row per
// fish (keyed by its Georgian name); managed from the admin panel.
model FishInfo {
  name  String  @id // Georgian species name, e.g. "კობრი"
  tip   String? // one short line of advice
  baits Json // array of { name, image_uri? }

  @@map("fish_info")
}

model Lake {
  id              Int     @id // matches the ids used by the app's lakesData.json
  nameKa          String  @map("name_ka")
  nameEn          String  @map("name_en")
  type            String // 'lake' | 'reservoir' | 'river'
  region          String
  latitude        Float
  longitude       Float
  areaKm2         Float?  @map("area_km2")
  maxDepthMeters  Float?  @map("max_depth_meters")
  description     String?
  // Array of { name_ka, name_en?, catch_difficulty } stored as JSON.
  fishSpecies     Json    @map("fish_species")

  catches  Catch[]
  comments Comment[]

  @@map("lakes")
}

model Catch {
  id        String   @id @default(cuid())
  imageUri  String   @map("image_uri")
  createdAt DateTime @default(now()) @map("created_at")

  lakeId Int  @map("lake_id")
  lake   Lake @relation(fields: [lakeId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lakeId])
  @@index([userId])
  @@map("catches")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  lakeId Int  @map("lake_id")
  lake   Lake @relation(fields: [lakeId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lakeId])
  @@index([userId])
  @@map("comments")
}
