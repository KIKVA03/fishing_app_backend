# ─────────────────────────────────────────────────────────────
#  FishMap backend configuration.
#  Copy this file to ".env" and fill in the values marked  <-- FILL IN
# ─────────────────────────────────────────────────────────────

# ── Supabase (PostgreSQL) ──────────────────────────────────────
# Get these from the Supabase dashboard:  Project → Connect → ORMs → Prisma.
#
# DATABASE_URL = the POOLED connection (Transaction pooler, port 6543).
#                The running app uses this. Keep "?pgbouncer=true".
# DIRECT_URL   = the DIRECT connection (Session pooler, port 5432).
#                Prisma uses this only for migrations (`prisma migrate`).
#
# Replace [PROJECT-REF], [PASSWORD] and [REGION] with your project's values.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"   # <-- FILL IN
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"                    # <-- FILL IN

# Secret used to sign JWT access tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"                                        # <-- FILL IN

# How long an access token stays valid (e.g. 7d, 24h, 30m).
JWT_EXPIRES_IN="30d"

# Port the API listens on.
PORT=4000

# Public base URL of THIS backend, used to build absolute image URLs
# returned to the app (e.g. http://192.168.1.10:4000/uploads/abc.jpg).
# In local dev on a phone, use your computer's LAN IP, not localhost.
PUBLIC_URL="http://localhost:4000"

# Allowed CORS origin(s), comma-separated. Use * to allow any (fine for the
# Expo app during development).
CORS_ORIGIN="*"
 